# -------------------------------------------------------
# KirokuMichi — Environment Variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Required: Anthropic API key for AI conversation practice and tutoring.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenRouter API key (alternative AI provider)
# OPENROUTER_API_KEY=

# Optional: DeepSeek API key (alternative AI provider)
# DEEPSEEK_API_KEY=

# Optional: OpenAI API key (alternative AI provider)
# OPENAI_API_KEY=

# Optional: OpenAI-compatible custom provider.
# Server key is only sent to CUSTOM_PROVIDER_ENDPOINT / CUSTOM_PROVIDER_ENDPOINTS.
# Client-supplied URLs never receive CUSTOM_PROVIDER_API_KEY.
# CUSTOM_PROVIDER_API_KEY=
# CUSTOM_PROVIDER_ENDPOINT=https://example.com/v1/chat/completions
# CUSTOM_PROVIDER_ENDPOINTS=https://example.com/v1/chat/completions

# Optional: restrict AI model names (comma-separated). When unset, a built-in safe pattern is used.
# AI_MODEL_ALLOWLIST=claude-haiku-4-5-20251001,claude-sonnet-4-6,deepseek-v4-flash

# Optional: GitHub issue sink for in-app reports.
# GITHUB_REPORT_REPO=owner/repo
# GITHUB_REPORT_TOKEN=

# Required on staging/prod: comma-separated invite codes for closed beta.
# Server issues an HttpOnly kiroku-beta-grant cookie; AI/PDF/report require it when enabled.
# BETA_INVITE_CODES=alpha-123,beta-456

# Optional: Sentry runtime error tracking.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=staging
# VITE_SENTRY_RELEASE=

# Optional: Comma-separated extra frontend origins if API is hosted separately.
# CORS_ORIGINS=https://kirokumichi-staging.example.com

# Optional: Ollama endpoint (local LLM, defaults to http://localhost:11434)
# OLLAMA_ENDPOINT=http://localhost:11434

# Server port (default: 3001)
# PORT=3001
