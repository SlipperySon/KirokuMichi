{
  "name": "kiroku-michi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "qa:routes": "playwright test",
    "verify": "npm run lint && npx tsc -b --pretty false && npm run test && npm run qa:routes && npm run build && npm run textbook:learner:quality && npm run textbook:maynard:direct-refs && npm run textbook:maynard:quality && npm run content:import:smoke && npm run textbook:assets:manifest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "ocr:build": "swiftc -framework AppKit -framework PDFKit -framework Vision tools/ocr/pdf-vision-ocr.swift -o tools/ocr/pdf-vision-ocr",
    "textbook:manifest": "tsx tools/textbook-pack/generate-source-manifest.ts",
    "textbook:ocr": "../.venv/bin/python tools/textbook-pack/ocr-full-capture.py",
    "textbook:normalize": "tsx tools/textbook-pack/normalize-ocr-pages.ts",
    "textbook:group": "tsx tools/textbook-pack/group-ocr-blocks.ts",
    "textbook:proof:genki": "tsx tools/textbook-pack/build-genki-lesson-proof.ts",
    "textbook:proof:quartet": "tsx tools/textbook-pack/build-quartet-lesson-proof.ts",
    "textbook:validation-images": "../.venv/bin/python tools/textbook-pack/render-validation-images.py",
    "textbook:assets:crop": "../.venv/bin/python tools/textbook-pack/crop-reviewed-assets.py",
    "textbook:validation-viewer": "tsx tools/textbook-pack/build-validation-viewer.ts",
    "textbook:corrections:init": "tsx tools/textbook-pack/init-corrections.ts",
    "textbook:corrections:apply": "tsx tools/textbook-pack/apply-corrections.ts",
    "textbook:answers:attach": "tsx tools/textbook-pack/attach-answer-ground-truth.ts",
    "textbook:reviewed:finalize": "tsx tools/textbook-pack/finalize-reviewed-pack.ts",
    "textbook:reviewed:report": "tsx tools/textbook-pack/report-reviewed-packs.ts",
    "textbook:reviewed:fingerprints": "tsx tools/textbook-pack/check-reviewed-fingerprints.ts",
    "textbook:reviewed:validate": "tsx tools/textbook-pack/validate-reviewed-pack.ts",
    "textbook:vocab:quality": "tsx tools/textbook-pack/repair-genki-vocab-quality.ts",
    "textbook:learner:quality": "tsx tools/textbook-pack/audit-learner-content-quality.ts",
    "textbook:maynard:direct-refs": "tsx tools/textbook-pack/build-maynard-direct-refs.ts",
    "textbook:maynard:quality": "tsx tools/textbook-pack/audit-maynard-coverage.ts",
    "content:import:smoke": "tsx tools/content-import-smoke.ts",
    "textbook:assets:manifest": "tsx tools/textbook-pack/build-textbook-asset-manifest.ts",
    "generate": "tsx tools/generate/pipeline.ts",
    "packs:build": "tsx tools/build-encrypted-packs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@tailwindcss/vite": "^4.2.4",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-intl": "^10.1.3",
    "react-router-dom": "^7.14.2",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.2.4",
    "ts-fsrs": "^5.3.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "xlsx": "^0.18.5"
  }
