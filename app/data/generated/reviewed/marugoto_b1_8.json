        {
          "id": "marugoto_b1_l8_grammar_7",
          "pattern": "ことにする",
          "meaning": "Expresses a personal decision or resolution to do something.",
          "explanation": "Attach ことにする to the plain form of a verb to indicate that the speaker has made a deliberate decision. It emphasizes the volitional act of choosing, often implying the decision was made after consideration. It is neutral in register and common in both spoken and written Japanese.",
          "examples": [
            {
              "japanese": "健康のために、毎日運動することにした。",
              "reading": "けんこうのために、まいにちうんどうすることにした。",
              "english": "I decided to exercise every day for my health."
            },
            {
              "japanese": "もう甘いものは食べないことにします。",
              "reading": "もうあまいものはたべないことにします。",
              "english": "I've decided not to eat sweets anymore."
            },
            {
              "japanese": "来年、日本語の試験を受けることにした。",
              "reading": "らいねん、にほんごのしけんをうけることにした。",
              "english": "I decided to take a Japanese language exam next year."
            }
          ],
