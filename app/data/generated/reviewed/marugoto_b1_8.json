        {
          "id": "marugoto_b1_l8_grammar_1",
          "pattern": "その結果",
          "meaning": "A conjunction meaning 'as a result' or 'consequently', used to present the outcome of a preceding situation.",
          "explanation": "その結果 links a cause or action to its outcome, functioning like 'as a result' or 'consequently' in English. It is more formal than そのため and is common in written Japanese, reports, and structured speech. It always follows a statement and introduces what happened because of it.",
          "examples": [
            {
              "japanese": "毎日トレーニングをした。その結果、大会で優勝することができた。",
              "reading": "まいにちトレーニングをした。そのけっか、たいかいでゆうしょうすることができた。",
              "english": "I trained every day. As a result, I was able to win the tournament."
            },
            {
              "japanese": "工場が川に汚水を流した。その結果、魚が大量に死んでしまった。",
              "reading": "こうじょうがかわにおすいをながした。そのけっか、さかながたいりょうにしんでしまった。",
              "english": "The factory discharged wastewater into the river. As a result, a large number of fish died."
            },
            {
              "japanese": "新しい薬を使い始めた。その結果、症状がかなり改善した。",
              "reading": "あたらしいくすりをつかいはじめた。そのけっか、しょうじょうがかなりかいぜんした。",
              "english": "They started using the new medicine. As a result, the symptoms improved considerably."
            }
          ],
