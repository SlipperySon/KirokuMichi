      "grammar": [
        {
          "id": "tobira_l14_grammar_1",
          "pattern": "恐れがある",
          "meaning": "There is a risk or fear that, Be in danger of, Possibility of",
          "explanation": "The noun 恐れ (fear, risk) combined with がある creates an expression indicating potential danger or negative outcome. It is more formal than simple possibility and is often used in news, reports, and formal speech. The pattern emphasizes concern about what might happen.",
          "examples": [
            {
              "japanese": "この政策により物価が上がる恐れがある。",
              "reading": "このせいさくによりぶっかがあがるおそれがある。",
              "english": "There is a risk that prices will rise due to this policy."
            },
            {
              "japanese": "プロジェクトが遅れる恐れがある。",
              "reading": "ぷろじぇくとがおくれるおそれがある。",
              "english": "There is a danger that the project will be delayed."
            },
            {
              "japanese": "感染が広がる恐れがある。",
              "reading": "かんせんがひろがるおそれがある。",
              "english": "There is a risk that the infection will spread."
            }
          ],
          "lessonNumber": 14,
          "sourceRef": {
            "sourceId": "tobira_textbook",
            "pageNumber": 1
          },
          "review": {
            "action": "approved",
            "reviewedAt": "2026-07-22T06:45:30.571Z",
            "reviewer": "marugoto_tobira_gold_enrich",
            "notes": "from comprehensive curriculum"
          }
        },
        {
          "id": "tobira_l14_grammar_2",
          "pattern": "を契機に",
          "meaning": "Indicates that an event served as the trigger or turning point for a subsequent change or action.",
          "explanation": "を契機に (also を契機として) follows a noun and means 'using X as an opportunity' or 'triggered by X'. It emphasizes that a particular event became the catalyst for a meaningful change. It is formal and typically used in written Japanese or formal speech to describe turning points.",
          "examples": [
            {
              "japanese": "その事故を契機に、会社は安全対策を見直した。",
              "reading": "そのじこをけいきに、かいしゃはあんぜんたいさくをみなおした。",
              "english": "The company reviewed its safety measures, triggered by that accident."
            },
            {
              "japanese": "留学を契機に、将来のキャリアを真剣に考えるようになった。",
              "reading": "りゅうがくをけいきに、しょうらいのキャリアをしんけんにかんがえるようになった。",
              "english": "Studying abroad became the trigger for me to seriously think about my future career."
            },
            {
              "japanese": "その出来事を契機として、二人の関係は大きく変わった。",
              "reading": "そのできごとをけいきとして、ふたりのかんけいはおおきくかわった。",
              "english": "That event became the turning point that significantly changed their relationship."
            }
          ],
          "lessonNumber": 14,
          "sourceRef": {
            "sourceId": "tobira_textbook",
            "pageNumber": 1
          },
          "review": {
            "action": "approved",
            "reviewedAt": "2026-07-22T06:45:30.571Z",
            "reviewer": "marugoto_tobira_gold_enrich",
            "notes": "from comprehensive curriculum"
          }
        },
        {
          "id": "tobira_l14_grammar_3",
          "pattern": "を巡って",
          "meaning": "Indicates that a discussion, conflict, or action revolves around or is over a particular issue or topic.",
          "explanation": "を巡って attaches to a noun and expresses that something — typically a debate, dispute, negotiation, or competition — is happening around or concerning that noun. It often carries a nuance of contention or multiple parties being involved. It is more formal than について and is frequently used in news, academic, and analytical writing.",
          "examples": [
            {
              "japanese": "土地の所有権を巡って、隣人との間で争いが起きた。",
              "reading": "とちのしょゆうけんをめぐって、りんじんとのあいだであらそいがおきた。",
              "english": "A dispute arose between neighbors over land ownership."
            },
            {
              "japanese": "新しい法案を巡って、国会で激しい議論が交わされた。",
              "reading": "あたらしいほうあんをめぐって、こっかいではげしいぎろんがかわされた。",
              "english": "Intense debate was exchanged in parliament over the new bill."
            },
            {
              "japanese": "その事件を巡っては、いまだに様々な意見がある。",
              "reading": "そのじけんをめぐっては、いまだにさまざまないけんがある。",
              "english": "Regarding that incident, various opinions still exist to this day."
            }
          ],
          "lessonNumber": 14,
          "sourceRef": {
            "sourceId": "tobira_textbook",
            "pageNumber": 1
          },
          "review": {
            "action": "approved",
            "reviewedAt": "2026-07-22T06:45:30.571Z",
            "reviewer": "marugoto_tobira_gold_enrich",
            "notes": "from comprehensive curriculum"
          }
        },
        {
          "id": "tobira_l14_grammar_4",
          "pattern": "おまけに",
          "meaning": "In addition, on top of that, what is more, to make matters worse",
          "explanation": "An adverbial expression that adds information sequentially, often implying that an additional circumstance makes a situation worse or more complicated. It connects two related situations or facts and suggests cumulative or worsening effect. Used in both formal and casual speech.",
          "examples": [
            {
              "japanese": "仕事は忙しいし、おまけに家事もある。",
              "reading": "しごとはいそがしいし、おまけにかじもある。",
              "english": "Work is busy, and on top of that, there is housework too."
            },
            {
