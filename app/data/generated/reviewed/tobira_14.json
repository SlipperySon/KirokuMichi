        {
          "id": "tobira_l14_grammar_14",
          "pattern": "たった(の)",
          "meaning": "Only, just, no more than a limited amount",
          "explanation": "This adverb or prefix emphasizes the smallness or limitation of a quantity, time, or scope. It can stand alone as an adverb or be followed by の to modify a noun directly. Used to express surprise or emphasis that something is remarkably small, brief, or inadequate.",
          "examples": [
            {
              "japanese": "たったの三人で始めた会社が今は大きくなった。",
              "reading": "たったのさんにんではじめたかいしゃがいまはおおきくなった。",
              "english": "The company that started with just three people has grown large."
            },
            {
              "japanese": "たった一日で全部終わった。",
              "reading": "たったいちにちですべておわった。",
              "english": "Everything was completed in just one day."
            },
            {
              "japanese": "たった五分の違いで全く結果が変わった。",
              "reading": "たったごふんのちがいでまったくけっかがかわった。",
              "english": "The outcome changed completely with just a five-minute difference."
            }
          ],
