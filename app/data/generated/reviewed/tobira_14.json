        {
          "id": "tobira_l14_grammar_8",
          "pattern": "ていては",
          "meaning": "Expresses that if a current action or state continues, a negative result will follow.",
          "explanation": "Formed by attaching ては to the te-form of a verb (ていては) or to a noun/adjective with で. It sets up a conditional that strongly implies criticism or warning — the speaker judges the ongoing action as problematic. Commonly used in advice-giving contexts; the result clause is typically negative or unfavorable.",
          "examples": [
            {
              "japanese": "毎晩ゲームばかりしていては、成績が上がるわけがない。",
              "reading": "まいばんゲームばかりしていては、せいせきがあがるわけがない。",
              "english": "If you keep playing games every night, there's no way your grades will improve."
            },
            {
              "japanese": "そんなに無理をしていては、体を壊してしまうよ。",
              "reading": "そんなにむりをしていては、からだをこわしてしまうよ。",
              "english": "If you keep pushing yourself that hard, you'll end up ruining your health."
            },
            {
              "japanese": "いつまでも迷っていては、チャンスを逃してしまう。",
              "reading": "いつまでもまよっていては、チャンスをのがしてしまう。",
              "english": "If you keep hesitating forever, you'll miss your chance."
            }
          ],
