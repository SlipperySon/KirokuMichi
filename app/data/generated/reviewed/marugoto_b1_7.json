        {
          "id": "marugoto_b1_l7_grammar_9",
          "pattern": "ことになる",
          "meaning": "Expresses that something has been decided, will end up happening, or is the result of circumstances.",
          "explanation": "Attach ことになる to the plain form of a verb to express that a situation or outcome has come about — often through external decisions or natural consequences rather than personal choice. This distinguishes it from ことにする, which reflects personal will. It is used in both formal and informal contexts.",
          "examples": [
            {
              "japanese": "来月から大阪に転勤することになった。",
              "reading": "らいげつからおおさかにてんきんすることになった。",
              "english": "It has been decided that I'll be transferred to Osaka starting next month."
            },
            {
              "japanese": "この道を選ぶと、遠回りすることになる。",
              "reading": "このみちをえらぶと、とおまわりすることになる。",
              "english": "If you choose this road, you'll end up going the long way around."
            },
            {
              "japanese": "彼が辞めたので、私が担当することになりました。",
              "reading": "かれがやめたので、わたしがたんとうすることになりました。",
              "english": "Since he quit, it has been decided that I will be in charge."
            }
          ],
