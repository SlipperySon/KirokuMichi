        {
          "id": "marugoto_b1_l12_grammar_11",
          "pattern": "は～くらいです",
          "meaning": "Highlights something as the sole or extreme example within a given scope.",
          "explanation": "This construction uses は to mark the topic and くらいです to indicate that the topic represents the approximate limit or the only significant example. It often conveys 'the only thing that comes close is…' or 'the most I can say is…'. It appears in neutral to polite speech and is useful for understated emphasis.",
          "examples": [
            {
              "japanese": "私にできることは、応援するくらいです。",
              "reading": "わたしにできることは、おうえんするくらいです。",
              "english": "About the only thing I can do is cheer you on."
            },
            {
              "japanese": "彼が得意なスポーツは水泳くらいです。",
              "reading": "かれがとくいなスポーツはすいえいくらいです。",
              "english": "About the only sport he's good at is swimming."
            },
            {
              "japanese": "私が知っている外国語は英語くらいです。",
              "reading": "わたしがしっているがいこくごはえいごくらいです。",
              "english": "About the only foreign language I know is English."
            }
          ],
