        {
          "id": "marugoto_b1_l12_grammar_5",
          "pattern": "はもちろん",
          "meaning": "Emphasizes something as obvious while adding additional, less obvious, or more significant items.",
          "explanation": "This pattern uses は plus もちろん to indicate that one thing is expected or obvious, and to add other items of note. It lists items where the first is already understood, but others deserve mention. Appropriate for both formal and casual discourse.",
          "examples": [
            {
              "japanese": "日本語はもちろん、中国語も話せます。",
              "reading": "にほんごはもちろん、ちゅうごくごもはなせます。",
              "english": "Not only Japanese, but I speak Chinese too."
            },
            {
              "japanese": "東京はもちろん、大阪にも行ったことがあります。",
              "reading": "とうきょうはもちろん、おおさかにもいったことがあります。",
              "english": "I've been to Tokyo, and I've also been to Osaka."
            },
            {
              "japanese": "大人はもちろん、子どもも楽しめます。",
              "reading": "おとなはもちろん、こどももたのしめます。",
              "english": "Adults can enjoy it, and so can children."
            }
          ],
